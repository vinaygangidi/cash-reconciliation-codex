# ─────────────────────────────────────────────────────────────
# REQUIRED - Azure AI Foundry connection
# ─────────────────────────────────────────────────────────────

# Your Azure AI Foundry endpoint URL
# Found at: ai.azure.com > your project > Overview > Endpoint
AZURE_AI_ENDPOINT=https://your-resource-name.services.ai.azure.com

# API key for local development
# Found at: ai.azure.com > your project > Overview > Keys
AZURE_API_KEY=your_api_key_here

# API version (leave this as-is unless Azure releases a newer version)
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ─────────────────────────────────────────────────────────────
# OPTIONAL - Demo vs live mode
# ─────────────────────────────────────────────────────────────

# Set to "true" to run on the built-in demo data (default)
# Set to "false" to process a real uploaded bank statement
USE_FIXTURES=true

# ─────────────────────────────────────────────────────────────
# OPTIONAL - Override which model each agent uses
# Defaults shown below. Swap to gpt-4o for higher accuracy
# or gpt-4o-mini for lower cost.
# ─────────────────────────────────────────────────────────────

# MODEL_BANK_AGENT=gpt-4o-mini
# MODEL_AR_AGENT=gpt-4o-mini
# MODEL_RECON_AGENT=gpt-4o
# MODEL_REASONING_AGENT=gpt-4o
# MODEL_POSTING_AGENT=gpt-4o

# ─────────────────────────────────────────────────────────────
# OPTIONAL - Azure services (needed only for full audit trail)
# ─────────────────────────────────────────────────────────────

# Azure Blob Storage - saves inputs and results per run
# AZURE_STORAGE_ACCOUNT_URL=https://youraccount.blob.core.windows.net

# Azure Application Insights - telemetry and traces
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
